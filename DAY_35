#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d", &n);

    int *queue = (int *)malloc(n * sizeof(int));
    int front = -1, rear = -1;

    for(int i = 0; i < n; i++) {
        int value;
        scanf("%d", &value);

        if(front == -1)
            front = 0;

        rear++;
        queue[rear] = value;
    }

    for(int i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }

    free(queue);
    return 0;
}
