#include <stdio.h>
#include <string.h>

int main()
{
    int n;
    scanf("%d",&n);

    int pq[1000];
    int size=0;

    for(int i=0;i<n;i++)
    {
        char op[10];
        scanf("%s",op);

        if(strcmp(op,"insert")==0)
        {
            int x;
            scanf("%d",&x);
            pq[size++]=x;
        }
        else if(strcmp(op,"delete")==0)
        {
            if(size==0)
            {
                printf("-1\n");
            }
            else
            {
                int min=0;
                for(int j=1;j<size;j++)
                    if(pq[j]<pq[min])
                        min=j;

                printf("%d\n",pq[min]);

                for(int j=min;j<size-1;j++)
                    pq[j]=pq[j+1];

                size--;
            }
        }
        else if(strcmp(op,"peek")==0)
        {
            if(size==0)
            {
                printf("-1\n");
            }
            else
            {
                int min=0;
                for(int j=1;j<size;j++)
                    if(pq[j]<pq[min])
                        min=j;

                printf("%d\n",pq[min]);
            }
        }
    }

    return 0;
}
