int size;

void inorder(struct TreeNode* root, int* arr){
    if(root==NULL)
        return;

    inorder(root->left, arr);
    arr[size++] = root->val;
    inorder(root->right, arr);
}

int* inorderTraversal(struct TreeNode* root, int* returnSize){

    int* arr = (int*)malloc(1000 * sizeof(int));
    size = 0;

    inorder(root, arr);

    *returnSize = size;

    return arr;
}
