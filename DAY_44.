int size=0;

void preorder(struct TreeNode* root,int* arr){
    if(root==NULL) return;
    
    arr[size++]=root->val;
    preorder(root->left,arr);
    preorder(root->right,arr);
}

int* preorderTraversal(struct TreeNode* root, int* returnSize){
    int* arr=(int*)malloc(1000*sizeof(int));
    size=0;
    
    preorder(root,arr);
    
    *returnSize=size;
    return arr;
}
