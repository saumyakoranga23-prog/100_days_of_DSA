int original;

void dfs(int** image, int imageSize, int* imageColSize, int sr, int sc, int color) {
    if (sr < 0 || sc < 0 || sr >= imageSize || sc >= imageColSize[0])
        return;

    if (image[sr][sc] != original)
        return;

    image[sr][sc] = color;

    dfs(image, imageSize, imageColSize, sr + 1, sc, color);
    dfs(image, imageSize, imageColSize, sr - 1, sc, color);
    dfs(image, imageSize, imageColSize, sr, sc + 1, color);
    dfs(image, imageSize, imageColSize, sr, sc - 1, color);
}

int** floodFill(int** image, int imageSize, int* imageColSize, int sr, int sc, int color, int* returnSize, int** returnColumnSizes) {
    
    *returnSize = imageSize;
    *returnColumnSizes = imageColSize;

    original = image[sr][sc];

    if (original == color)
        return image;

    dfs(image, imageSize, imageColSize, sr, sc, color);

    return image;
}
