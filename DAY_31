#include <stdio.h>
#define MAX 100

int main() {
    int n, m;
    int stack[MAX];
    int top = -1;

    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        int value;
        scanf("%d", &value);
        if(top < MAX - 1) {
            top++;
            stack[top] = value;
        }
    }

    scanf("%d", &m);

    for(int i = 0; i < m; i++) {
        if(top >= 0) {
            top--;
        }
    }

    for(int i = top; i >= 0; i--) {
        printf("%d", stack[i]);
        if(i != 0)
            printf(" ");
    }

    return 0;
}
